# ── Gemini API Keys (1 primary + 2 fallback for automatic rotation on 429) ──
# Primary: use a paid key with higher RPM for production reliability
GEMINI_API_KEY_PRIMARY=your_paid_gemini_key_here
# Fallbacks: free-tier keys from Google AI Studio
GEMINI_API_KEY_FALLBACK_1=your_free_key_1_here
GEMINI_API_KEY_FALLBACK_2=your_free_key_2_here

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname

# ── External Services ────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key_here
JINA_API_KEY=your_jina_key_here

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ── WhatsApp / Twilio (optional) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
